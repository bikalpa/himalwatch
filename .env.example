# Cloudflare R2 — get from R2 → Manage R2 API Tokens
R2_ENDPOINT_URL=https://ACCOUNT_ID.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=himalwatch-data
R2_PUBLIC_URL=https://pub-PLACEHOLDER.r2.dev

# Google Earth Engine — for local runs only
# For CI, use GEE_SERVICE_ACCOUNT_KEY (base64 JSON) as a GitHub secret instead
GEE_PROJECT=your-gcp-project-id
